        <!-- SECTION 5: SIGNAL PROCESSING -->
        <mxCell id="s5_header" value="5. Signal Processing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#854F0B;fontColor=#633806;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1360" y="260" width="280" height="45" as="geometry" />
