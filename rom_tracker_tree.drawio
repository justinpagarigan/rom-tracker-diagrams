  <diagram id="page5" name="Dev Roadmap">
    <mxGraphModel dx="1622" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="PoC Development Roadmap &#x2014; Wearable ROM Tracker" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=22;fontColor=#26215C;" vertex="1" parent="1"><mxGeometry x="300" y="30" width="1800" height="50" as="geometry" /></mxCell>
        <mxCell id="subtitle" value="Last updated: June 28, 2026" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontColor=#888780;" vertex="1" parent="1"><mxGeometry x="300" y="75" width="1800" height="24" as="geometry" /></mxCell>
        <mxCell id="ph1_hdr" value="Phase 1 &#x2014; Firmware" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#0F6E56;fontColor=#085041;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="60" y="130" width="380" height="50" as="geometry" /></mxCell>
        <mxCell id="ph1_badge" value="&#x1F7E2; Current focus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF3DE;strokeColor=#639922;fontColor=#27500A;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="185" width="380" height="28" as="geometry" /></mxCell>
        <mxCell id="ph1_b1" value="[ ] Set up Arduino IDE + Adafruit nRF52 board package" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="225" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph1_b2" value="[ ] Install ArduinoBLE + Seeed_Arduino_LSM6DS3 libraries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="265" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph1_b3" value="[ ] Read LSM6DS3 quaternions (q.w, q.x, q.y, q.z)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="305" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph1_b4" value="[ ] Compute elbow angle: q_rel = q1_conj * q2, extract angle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="345" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph1_b5" value="[ ] Rep counter: flex &gt;120 deg then &lt;30 deg = 1 rep" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="385" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph1_b6" value="[ ] BLE GATT service + notify characteristic (custom UUID)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="425" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph1_b7" value="[ ] Stream packet: [angle_float | rep_int | timestamp_ms]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="465" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph1_b8" value="[ ] Deep sleep duty cycle (5uA idle target)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="505" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph1_out" value="Output: Both XIAOs streaming angle + rep over BLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1EFE8;strokeColor=#888780;fontColor=#444441;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="550" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph2_hdr" value="Phase 2 &#x2014; Physical Attachment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#0F6E56;fontColor=#085041;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="480" y="130" width="380" height="50" as="geometry" /></mxCell>
        <mxCell id="ph2_b1" value="[ ] Mount XIAO on upper arm (watch strap / velcro ~24mm)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="480" y="225" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph2_b2" value="[ ] Mount XIAO on forearm (same strap approach)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="480" y="265" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph2_b3" value="[ ] Route LiPo cable cleanly alongside strap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="480" y="305" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph2_b4" value="[ ] Verify sensors stay stable through full bicep curl motion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="480" y="345" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph2_out" value="Output: Stable dual-sensor wearable on both arms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1EFE8;strokeColor=#888780;fontColor=#444441;fontSize=11;" vertex="1" parent="1"><mxGeometry x="480" y="550" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph3_hdr" value="Phase 3 &#x2014; Sensor Placement + Calibration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#0F6E56;fontColor=#085041;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="900" y="130" width="380" height="50" as="geometry" /></mxCell>
        <mxCell id="ph3_b1" value="[ ] Orient upper arm sensor: flat on bicep, cable down" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="900" y="225" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph3_b2" value="[ ] Orient forearm sensor aligned to upper arm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="900" y="265" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph3_b3" value="[ ] Calibration: arm straight = 0 deg reference" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="900" y="305" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph3_b4" value="[ ] Validate angle vs goniometer (target +-5 deg)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="900" y="345" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph3_b5" value="[ ] Track min/max ROM per rep + log per-set averages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#9FE1CB;fontColor=#085041;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="900" y="385" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph3_out" value="Output: Accurate elbow ROM +-5 deg during bicep curls" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1EFE8;strokeColor=#888780;fontColor=#444441;fontSize=11;" vertex="1" parent="1"><mxGeometry x="900" y="550" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph4_hdr" value="Phase 4 &#x2014; Mobile App" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#854F0B;fontColor=#633806;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1320" y="130" width="380" height="50" as="geometry" /></mxCell>
        <mxCell id="ph4_b1" value="[ ] Choose: MIT App Inventor (PoC) or Flutter (prod)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#FAC775;fontColor=#633806;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1320" y="225" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph4_b2" value="[ ] BLE scan + connect to both XIAOs by name/UUID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#FAC775;fontColor=#633806;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1320" y="265" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph4_b3" value="[ ] Subscribe to GATT notify (angle + rep packets)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#FAC775;fontColor=#633806;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1320" y="305" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph4_b4" value="[ ] Parse bytes - display live elbow angle line chart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#FAC775;fontColor=#633806;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1320" y="345" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph4_b5" value="[ ] Large rep counter display + set timer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#FAC775;fontColor=#633806;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1320" y="385" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph4_b6" value="[ ] Session summary: avg ROM, best ROM, total reps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#FAC775;fontColor=#633806;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1320" y="425" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph4_out" value="Output: Working app with live ROM chart + rep counter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1EFE8;strokeColor=#888780;fontColor=#444441;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1320" y="550" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph5_hdr" value="Phase 5 &#x2014; Live Tracking + Validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#534AB7;fontColor=#3C3489;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1740" y="130" width="380" height="50" as="geometry" /></mxCell>
        <mxCell id="ph5_b1" value="[ ] Full bilateral session: left + right bicep curl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#AFA9EC;fontColor=#3C3489;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1740" y="225" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph5_b2" value="[ ] Asymmetry detection: left vs right ROM per rep" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#AFA9EC;fontColor=#3C3489;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1740" y="265" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph5_b3" value="[ ] Form alert: flag rep if ROM drops below baseline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#AFA9EC;fontColor=#3C3489;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1740" y="305" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph5_b4" value="[ ] Longitudinal history: chart ROM trend across sessions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#AFA9EC;fontColor=#3C3489;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1740" y="345" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph5_b5" value="[ ] Expand to 2nd exercise (squat or shoulder press)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#AFA9EC;fontColor=#3C3489;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1740" y="385" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph5_b6" value="[ ] Final accuracy validation vs goniometer (+-5 deg)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#AFA9EC;fontColor=#3C3489;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1740" y="425" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="ph5_out" value="Output: Full PoC - bilateral ROM tracker for bicep curls" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1EFE8;strokeColor=#888780;fontColor=#444441;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1740" y="550" width="380" height="36" as="geometry" /></mxCell>
        <mxCell id="arr1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#888780;strokeWidth=2;" edge="1" source="ph1_hdr" target="ph2_hdr" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arr2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#888780;strokeWidth=2;" edge="1" source="ph2_hdr" target="ph3_hdr" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arr3" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#888780;strokeWidth=2;" edge="1" source="ph3_hdr" target="ph4_hdr" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arr4" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#888780;strokeWidth=2;" edge="1" source="ph4_hdr" target="ph5_hdr" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="note1" value="Key formula: q_relative = q1_conjugate * q2 | angle = 2*acos(q_rel.w) | Quaternions avoid gimbal lock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#633806;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="615" width="500" height="50" as="geometry" /></mxCell>
        <mxCell id="note2" value="Battery: Active 7-15mA | Idle 1-3mA | Deep sleep 5uA | 150mAh / ~12mA avg = ~12hrs active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#633806;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="580" y="615" width="500" height="50" as="geometry" /></mxCell>
        <mxCell id="note3" value="App: MIT App Inventor for fastest PoC (days). Upgrade to Flutter for production when PoC validated." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#633806;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1100" y="615" width="500" height="50" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page6" name="Sensor Math">
    <mxGraphModel dx="1622" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="sm_title" value="Sensor Math &#x2014; Wearable ROM Tracker" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=22;fontColor=#26215C;" vertex="1" parent="1"><mxGeometry x="400" y="30" width="1200" height="50" as="geometry" /></mxCell>
        <mxCell id="sm_sub" value="How the firmware converts raw sensor data into an elbow angle" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontColor=#888780;" vertex="1" parent="1"><mxGeometry x="400" y="75" width="1200" height="24" as="geometry" /></mxCell>

        <mxCell id="sm_s1h" value="Stage 1: Read raw accelerometer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#0F6E56;fontColor=#085041;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="60" y="130" width="420" height="50" as="geometry" /></mxCell>
        <mxCell id="sm_s1b" value="&#x2022; LSM6DS3 outputs three values: ax, ay, az&#xa;&#x2022; These measure gravity pull along each axis (in g-force units)&#xa;&#x2022; Flat on table: (0, 0, 1.0) &#x2014; all gravity in Z&#xa;&#x2022; Tilted: gravity shifts into X and Y&#xa;&#x2022; During fast motion: values include acceleration + gravity mixed" style="text;html=1;strokeColor=#9FE1CB;fillColor=#E1F5EE;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#085041;rounded=1;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="60" y="185" width="420" height="110" as="geometry" /></mxCell>

        <mxCell id="sm_s2h" value="Stage 2: Normalize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#0F6E56;fontColor=#085041;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="520" y="130" width="420" height="50" as="geometry" /></mxCell>
        <mxCell id="sm_s2b" value="&#x2022; norm = sqrt(ax&#xb2; + ay&#xb2; + az&#xb2;)&#xa;&#x2022; Then: ax /= norm, ay /= norm, az /= norm&#xa;&#x2022; Forces total magnitude to exactly 1.0&#xa;&#x2022; Strips out motion artifacts &#x2014; keeps only direction of gravity&#xa;&#x2022; Without this: fast movements cause 5-10 deg angle drift" style="text;html=1;strokeColor=#9FE1CB;fillColor=#E1F5EE;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#085041;rounded=1;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="520" y="185" width="420" height="110" as="geometry" /></mxCell>

        <mxCell id="sm_s2ex" value="Example: Raw during curl (0.15, 0.85, 0.45) mag=0.97 | After normalize (0.15, 0.88, 0.46) mag=1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#633806;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="520" y="300" width="420" height="44" as="geometry" /></mxCell>

        <mxCell id="sm_s3h" value="Stage 3: Build quaternion from gravity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#854F0B;fontColor=#633806;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="60" y="390" width="420" height="50" as="geometry" /></mxCell>
        <mxCell id="sm_s3b" value="&#x2022; qw = sqrt(0.5 x (az + 1.0))&#xa;&#x2022; qx = -ay / (2 x qw)&#xa;&#x2022; qy = ax / (2 x qw)&#xa;&#x2022; qz = 0.0 (transverse plane ignored)&#xa;&#x2022; Quaternion = 4-number 3D orientation (w, x, y, z)&#xa;&#x2022; Better than Euler angles: avoids gimbal lock&#xa;&#x2022; Simplified: accelerometer only, no gyroscope fusion yet" style="text;html=1;strokeColor=#FAC775;fillColor=#FAEEDA;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#633806;rounded=1;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="60" y="445" width="420" height="140" as="geometry" /></mxCell>

        <mxCell id="sm_s3note" value="qz = 0 means: X tilt (frontal plane) captured | Y tilt (sagittal/curl plane) captured | Z twist (wrist rotation) ignored" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#633806;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="60" y="590" width="420" height="44" as="geometry" /></mxCell>

        <mxCell id="sm_s4h" value="Stage 4: Compute angle between two quaternions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#534AB7;fontColor=#3C3489;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="520" y="390" width="420" height="50" as="geometry" /></mxCell>
        <mxCell id="sm_s4b" value="&#x2022; Step A: Conjugate q1 (upper arm) &#x2192; (w1, -x1, -y1, -z1)&#xa;  &#x2014; Un-rotates the upper arm orientation&#xa;&#x2022; Step B: Multiply conjugate x q2 (forearm)&#xa;  &#x2014; rw = cw*w2 - cx*x2 - cy*y2 - cz*z2&#xa;  &#x2014; Result = rotation FROM upper arm TO forearm = elbow bend&#xa;&#x2022; Step C: Clamp rw to [-1, 1] (prevents acos crash)&#xa;&#x2022; Step D: angle = 2 x acos(rw) x 180 / pi" style="text;html=1;strokeColor=#AFA9EC;fillColor=#EEEDFE;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#3C3489;rounded=1;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="520" y="445" width="420" height="150" as="geometry" /></mxCell>

        <mxCell id="sm_s4ex" value="rw=1.0 &#x2192; 0 deg (straight) | rw=0.87 &#x2192; 60 deg | rw=0.5 &#x2192; 120 deg (full curl)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#633806;fontSize=11;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="520" y="600" width="420" height="36" as="geometry" /></mxCell>

        <mxCell id="sm_keyh" value="Key insight: why two sensors are required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAECE7;strokeColor=#993C1D;fontColor=#712B13;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="60" y="680" width="880" height="50" as="geometry" /></mxCell>
        <mxCell id="sm_keyb" value="&#x2022; A single IMU knows its own tilt but NOT what the rest of the arm is doing&#xa;&#x2022; Raise whole arm straight up: sensor tilts 90 deg, but elbow angle = 0 deg&#xa;&#x2022; Curl forearm only: sensor tilts 90 deg, but elbow angle = 90 deg&#xa;&#x2022; One sensor cannot tell these apart &#x2014; same tilt, different joint angle&#xa;&#x2022; The DELTA between two sensors cancels body movement and isolates the joint" style="text;html=1;strokeColor=#F5C4B3;fillColor=#FAECE7;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#712B13;rounded=1;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="60" y="735" width="880" height="110" as="geometry" /></mxCell>

        <mxCell id="sm_arr1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#888780;strokeWidth=2;" edge="1" source="sm_s1h" target="sm_s2h" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sm_arr2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#888780;strokeWidth=2;" edge="1" source="sm_s2h" target="sm_s3h" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sm_arr3" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#888780;strokeWidth=2;" edge="1" source="sm_s3h" target="sm_s4h" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>


