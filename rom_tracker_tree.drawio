        <mxCell id="s4_v3" value="📖 Adafruit GATT Guide&#xa;learn.adafruit.com/introduction-to-bluetooth-low-energy/gatt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#2196F3;fontSize=11;align=left;" vertex="1" parent="1">
