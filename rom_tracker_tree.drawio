        <mxCell id="v8" value="Cloud sync&#xa;Longitudinal tracking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#7F77DD;fontColor=#3C3489;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1770" y="530" width="155" height="50" as="geometry"/></mxCell>
