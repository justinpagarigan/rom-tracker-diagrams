        <mxCell id="eap8" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#EF9F27;" edge="1" source="b4" target="ap8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- V2 & FUTURE -->
        <mxCell id="v1" value="Smart sleeve&#xa;Single joint target" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#7F77DD;fontColor=#3C3489;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1600" y="320" width="155" height="50" as="geometry"/></mxCell>
        <mxCell id="v2" value="Custom PCB&#xa;nRF52840 chip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#7F77DD;fontColor=#3C3489;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1770" y="320" width="155" height="50" as="geometry"/></mxCell>
        <mxCell id="v3" value="More exercises&#xa;Squat, shoulder, deadlift" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#7F77DD;fontColor=#3C3489;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1600" y="390" width="155" height="50" as="geometry"/></mxCell>
