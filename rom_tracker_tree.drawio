        <mxCell id="s5_proj" value="🔗 Project: Smooth angle stream → detect rep peaks → log ROM per rep" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=11;align=left;" vertex="1" parent="1">
