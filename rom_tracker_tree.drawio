        <mxCell id="s4_proj" value="🔗 Project: Custom GATT service to stream bilateral joint angles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="1040" y="570" width="280" height="35" as="geometry" />
