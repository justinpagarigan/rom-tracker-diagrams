        <mxCell id="a2c" value="Simpler fusion — mixes gyro short-term + accel long-term" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="890" y="750" width="170" height="40" as="geometry"/></mxCell>

        <mxCell id="a3a" value="IIR" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#ccc;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="580" y="795" width="100" height="40" as="geometry"/></mxCell>
        <mxCell id="a3b" value="Infinite Impulse Response (filter type)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#ccc;fontSize=11;align=left;" vertex="1" parent="1"><mxGeometry x="685" y="795" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="a3c" value="Common digital filter type for smoothing sensor data" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="890" y="795" width="170" height="40" as="geometry"/></mxCell>

        <mxCell id="a4a" value="FIR" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#ccc;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="580" y="840" width="100" height="40" as="geometry"/></mxCell>
        <mxCell id="a4b" value="Finite Impulse Response (filter type)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#ccc;fontSize=11;align=left;" vertex="1" parent="1"><mxGeometry x="685" y="840" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="a4c" value="Alt filter — more stable, higher compute cost" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="890" y="840" width="170" height="40" as="geometry"/></mxCell>

        <mxCell id="a5a" value="PID" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#ccc;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="580" y="885" width="100" height="40" as="geometry"/></mxCell>
        <mxCell id="a5b" value="Proportional-Integral-Derivative (controller)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#ccc;fontSize=11;align=left;" vertex="1" parent="1"><mxGeometry x="685" y="885" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="a5c" value="Not used here — common in robotics/motor control" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="890" y="885" width="170" height="40" as="geometry"/></mxCell>

        <!-- LEGEND -->
        <mxCell id="legend_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#ccc;" vertex="1" parent="1">
          <mxGeometry x="1100" y="630" width="480" height="100" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" value="Legend" style="text;html=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=13;align=left;" vertex="1" parent="1">
          <mxGeometry x="1115" y="638" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="leg_hw" value="Green header = Hardware / Firmware" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#0F6E56;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1115" y="665" width="220" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg_bl" value="Orange header = Wireless / App" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#854F0B;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1345" y="665" width="220" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg_pu" value="Purple header = Math / Algorithms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#534AB7;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1115" y="698" width="220" height="28" as="geometry" />
